# ─── Firebase web config ───────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in the real values, then restart
# `npm run dev`. `.env.local` is git-ignored — NEVER commit real values.
#
# Where to get the values:
#   • Firebase Console → Project settings → General → "Your apps" → SDK config
#   • or, if you have access to the Vercel project:  vercel env pull
#   • or ask the project owner
#
# Note: these VITE_* vars are bundled into the client (they ship to the browser),
# so they are not secrets — but keep them out of git anyway.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
